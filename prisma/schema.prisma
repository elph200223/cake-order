generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrderStatus {
  PENDING_PAYMENT
  PAID
  CANCELLED
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  REJECTED
}

model Reservation {
  id            Int               @id @default(autoincrement())
  posId         String?           @unique  // UUID from POS app
  lineUserId    String?
  customerName  String
  phone         String
  adults        Int               @default(1)
  children      Int               @default(0)
  requestDate   String
  requestTime   String
  note          String            @default("")
  status        ReservationStatus @default(PENDING)
  title         String            @default("")        // 先生 / 小姐 / ""
  arrivalStatus String            @default("pending") // pending / arrived / noShow
  preorderItems String            @default("[]")      // JSON
  source        String            @default("web")     // web / pos
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
}

model ReservationSetting {
  id             Int    @id @default(autoincrement())
  confirmMessage String @default("您好！您的訂位已確認，期待您的到來！如有任何問題歡迎隨時詢問 🙏")
  rejectMessage  String @default("您好！非常抱歉，您所希望的時段目前已滿，如有需要請再與我們聯繫，謝謝您的理解 🙏")
}

enum SiteImageSlot {
  HOME_HERO
}

enum ProductType {
  CAKE
  COFFEE
}

model Order {
  id          Int         @id @default(autoincrement())
  orderNo     String      @unique
  customer    String
  phone       String
  email       String      @default("")
  pickupDate  String
  pickupTime  String
  note        String      @default("")
  status      OrderStatus @default(PENDING_PAYMENT)
  totalAmount Int
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  items OrderItem[]
}

model OrderItem {
  id       Int   @id @default(autoincrement())
  order    Order @relation(fields: [orderId], references: [id])
  orderId  Int
  name     String
  price    Int
  quantity Int
}

model Product {
  id          Int         @id @default(autoincrement())
  name        String
  slug        String      @unique
  productType ProductType @default(CAKE)
  basePrice   Int
  description String      @default("")
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  optionGroups ProductOptionGroup[]
  images       ProductImage[]

  @@index([productType, isActive])
}

model OptionGroup {
  id        Int     @id @default(autoincrement())
  name      String
  required  Boolean @default(false)
  minSelect Int     @default(0)
  maxSelect Int     @default(1)

  sort      Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  options  Option[]
  products ProductOptionGroup[]
}

model Option {
  id            Int         @id @default(autoincrement())
  name          String
  priceDelta    Int         @default(0)
  optionGroup   OptionGroup @relation(fields: [optionGroupId], references: [id])
  optionGroupId Int

  sort      Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([optionGroupId])
}

model ProductOptionGroup {
  id            Int         @id @default(autoincrement())
  product       Product     @relation(fields: [productId], references: [id])
  productId     Int
  optionGroup   OptionGroup @relation(fields: [optionGroupId], references: [id])
  optionGroupId Int

  sort Int @default(0)

  @@unique([productId, optionGroupId])
  @@index([optionGroupId])
}

model SiteImage {
  id              Int           @id @default(autoincrement())
  slot            SiteImageSlot @unique
  originalName    String
  mimeType        String
  storageKey      String        @unique
  url             String
  width           Int?
  height          Int?
  sizeBytes       Int?
  compressedBytes Int?
  alt             String        @default("")
  isActive        Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model ProductImage {
  id              Int      @id @default(autoincrement())
  product         Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId       Int
  originalName    String
  mimeType        String
  storageKey      String   @unique
  url             String
  width           Int?
  height          Int?
  sizeBytes       Int?
  compressedBytes Int?
  alt             String   @default("")
  sort            Int      @default(0)
  isCover         Boolean  @default(false)
  isActive        Boolean  @default(true)
  focusX          Int      @default(50)
  focusY          Int      @default(50)
  zoom            Int      @default(100)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([productId])
  @@index([productId, sort])
}

model PickupBlockDate {
  id        Int      @id @default(autoincrement())
  date      String   @unique
  reason    String   @default("")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, date])
}